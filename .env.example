# Dynamics 365 CRM MCP Server - Environment Variables
# Copy this to .env and fill in your values

# Your Dynamics 365 instance URL (default: https://microsoftsales.crm.dynamics.com)
DYNAMICS_BASE_URL=https://microsoftsales.crm.dynamics.com

# Azure AD app registration client ID (required)
DYNAMICS_CLIENT_ID=

# Azure AD tenant ID (required)
DYNAMICS_TENANT_ID=

# Your systemuserid GUID from Dynamics 365 (required)
# Find yours at: https://<instance>.crm.dynamics.com/api/data/v9.2/systemusers?$filter=internalemailaddress eq 'you@company.com'&$select=systemuserid,fullname
DYNAMICS_USER_ID=
